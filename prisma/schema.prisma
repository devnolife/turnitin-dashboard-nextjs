generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(cuid())
  username            String        @unique
  password            String
  passwordHash        String?
  name                String
  nim                 String?       @unique
  hp                  String?
  email               String?
  prodi               String?
  role                Role          @default(STUDENT)
  hasCompletedPayment Boolean       @default(false)
  whatsappNumber      String?
  mustChangePassword  Boolean       @default(false)
  accountStatus       AccountStatus @default(ACTIVE)
  graduatedAt         DateTime?
  tourCompletedAt     DateTime?
  studyProgramId      String?
  instructorId        String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  studyProgram        StudyProgram? @relation(fields: [studyProgramId], references: [id])
  instructor          User?         @relation("InstructorStudents", fields: [instructorId], references: [id])
  students            User[]        @relation("InstructorStudents")
  examDetails         ExamDetail?
  submissions         Submission[]  @relation("UserSubmissions")
  reviewedSubmissions Submission[]  @relation("ReviewerSubmissions")
  payments            Payment[]
  sessions            Session[]
  complaints          Complaint[]   @relation("UserComplaints")
  respondedComplaints Complaint[]   @relation("ResponderComplaints")

  @@index([instructorId])
  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  jti       String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Faculty {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programs StudyProgram[]

  @@map("faculties")
}

model StudyProgram {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  degree    String   @default("S1")
  facultyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faculty         Faculty          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  similarityRules SimilarityRule[]
  users           User[]

  @@map("study_programs")
}

model SimilarityRule {
  id             String   @id @default(cuid())
  studyProgramId String
  ruleType       RuleType
  label          String
  maxPercentage  Float
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  studyProgram StudyProgram @relation(fields: [studyProgramId], references: [id], onDelete: Cascade)

  @@unique([studyProgramId, label])
  @@index([studyProgramId, ruleType])
  @@map("similarity_rules")
}

model ExamDetail {
  id             String         @id @default(cuid())
  userId         String         @unique
  thesisTitle    String
  examType       ExamType
  approvalStatus ApprovalStatus @default(PENDING)
  submittedAt    DateTime       @default(now())
  reviewedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("exam_details")
}

model Submission {
  id                 String           @id @default(cuid())
  userId             String
  documentTitle      String
  documentUrl        String?
  // File mahasiswa (uploaded once at create time)
  fileName           String?
  fileSize           Int?
  fileMimeType       String?
  // Klasifikasi
  examType           ExamType?
  chapter            String?
  // Hasil dari instruktur
  similarityScore    Float?
  // Batas % similarity KHUSUS dokumen ini (override aturan prodi). null = pakai aturan prodi.
  thresholdOverride  Float?
  status             SubmissionStatus @default(PENDING)
  reportUrl          String?
  reportFileName     String?
  reportFileSize     Int?
  reportMimeType     String?
  reportUploadedAt   DateTime?
  rejectionReason    String?
  reviewedBy         String?
  reviewedAt         DateTime?
  // Turnitin automasi (RPA) — diisi oleh worker bot
  turnitinPaperId    String?
  autoCheckError     String?
  autoCheckedAt      DateTime?
  // Integrity Flags dari Turnitin (jumlah; 0 = bersih, null = belum/ tak terbaca).
  integrityFlags     Int?
  // Penyesuaian manual hasil (override + audit) oleh instruktur/admin.
  // turnitinRawScore = skor ASLI Turnitin (disimpan permanen saat override pertama).
  turnitinRawScore      Float?
  scoreAdjustedBy       String?
  scoreAdjustedByName   String?
  scoreAdjustedAt       DateTime?
  scoreAdjustmentReason String?
  // Resubmit history
  version            Int              @default(1)
  parentSubmissionId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user         User          @relation("UserSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  reviewer     User?         @relation("ReviewerSubmissions", fields: [reviewedBy], references: [id], onDelete: SetNull)
  parent       Submission?   @relation("SubmissionResubmits", fields: [parentSubmissionId], references: [id], onDelete: SetNull)
  children     Submission[]  @relation("SubmissionResubmits")
  turnitinJobs TurnitinJob[]

  @@index([userId, examType])
  @@index([status, createdAt(sort: Desc)])
  @@index([reviewedBy])
  @@map("submissions")
}

/// Antrian job otomasi Turnitin. Worker (Playwright) mengambil job QUEUED,
/// submit dokumen ke Turnitin via Quick Submit, lalu menulis hasil ke Submission.
model TurnitinJob {
  id              String            @id @default(cuid())
  submissionId    String
  status          TurnitinJobStatus @default(QUEUED)
  attempts        Int               @default(0)
  maxAttempts     Int               @default(3)
  turnitinPaperId String?
  errorCode       String?
  lastError       String?
  lockedAt        DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([submissionId])
  @@map("turnitin_jobs")
}

model PricingTier {
  id             String   @id @default(cuid())
  degree         String   @unique
  studentRate    Int
  instructorRate Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("pricing_tiers")
}

model RekapArchive {
  id              String   @id @default(cuid())
  periodeMonth    Int
  periodeYear     Int
  periodeLabel    String
  studyProgramId  String?
  instructorId    String?
  filterSummary   String?
  fileName        String
  fileSize        Int
  fileData        Bytes
  totalItems      Int      @default(0)
  totalAmount     Int      @default(0)
  generatedById   String?
  generatedByName String?
  createdAt       DateTime @default(now())

  @@index([periodeYear, periodeMonth])
  @@index([createdAt])
  @@map("rekap_archives")
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  amount          Float
  status          PaymentStatus @default(PENDING)
  paymentMethod   String?
  jenisPembayaran String?
  periode         String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Complaint {
  id            String          @id @default(cuid())
  userId        String
  subject       String
  message       String          @db.Text
  status        ComplaintStatus @default(OPEN)
  response      String?         @db.Text
  respondedById String?
  createdAt     DateTime        @default(now())
  respondedAt   DateTime?
  updatedAt     DateTime        @updatedAt

  user        User  @relation("UserComplaints", fields: [userId], references: [id], onDelete: Cascade)
  respondedBy User? @relation("ResponderComplaints", fields: [respondedById], references: [id])

  @@index([userId])
  @@index([status])
  @@map("complaints")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  targetType String?
  targetId   String?
  ip         String?
  userAgent  String?  @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum ExamType {
  PROPOSAL_DEFENSE
  RESULTS_DEFENSE
  FINAL_DEFENSE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  REVIEWED
  FLAGGED
}

enum TurnitinJobStatus {
  QUEUED
  RUNNING
  WAITING_REPORT
  SUCCEEDED
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RuleType {
  PER_CHAPTER
  PER_EXAM
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}
